{
  "name": "trojan-1888",
  "version": "5.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 2>&1 | tee dev.log",
    "build": "next build",
    "build:cloudflare": "next build && npx --yes @cloudflare/next-on-pages@1 --legacy-peer-deps",
    "start": "next start",
    "lint": "eslint .",
